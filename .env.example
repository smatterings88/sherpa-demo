# Required for script generation (server only)
OPENAI_API_KEY=

# Required for text-to-speech (server only)
ELEVENLABS_API_KEY=

# Optional: override default ElevenLabs voice IDs
# ELEVENLABS_VOICE_PROSPECT=
# ELEVENLABS_VOICE_REP=
# ELEVENLABS_VOICE_ALEX=

# Optional: upload TTS segments to Vercel Blob (tiny JSON response; avoids 4.5MB limits).
# Create a Blob store in the Vercel dashboard and paste the read/write token here.
# BLOB_READ_WRITE_TOKEN=

# Shown in the UI header and metadata
NEXT_PUBLIC_APP_NAME=Alex the Sherpa
