# Required for script generation (server only)
OPENAI_API_KEY=

# Required for text-to-speech (server only). xi-api-key from Profile → API key.
# If curl works locally but Vercel gets sign_in_required: re-paste the key (removes hidden
# whitespace) and ensure Production + Preview envs both have it. EU residency accounts may need:
# ELEVENLABS_API_BASE_URL=https://api.eu.residency.elevenlabs.io
ELEVENLABS_API_KEY=
# ELEVENLABS_API_BASE_URL=https://api.elevenlabs.io

# Optional: TTS model (default eleven_multilingual_v2). Example: eleven_turbo_v2_5
# ELEVENLABS_MODEL_ID=

# Optional: override default ElevenLabs voice IDs
# ELEVENLABS_VOICE_PROSPECT=
# ELEVENLABS_VOICE_REP=
# ELEVENLABS_VOICE_ALEX=

# Strongly recommended on Vercel: Storage → Blob → link store (sets BLOB_READ_WRITE_TOKEN).
# Some setups use VERCEL_BLOB_READ_WRITE_TOKEN instead.
# BLOB_READ_WRITE_TOKEN=

# Shown in the UI header and metadata
NEXT_PUBLIC_APP_NAME=Alex the Sherpa
